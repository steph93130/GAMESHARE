<div class="header-profil">
  <%= link_to edit_user_registration_path do %><%= image_tag "logo-game.png",
          alt: "Profile",
          class: "logo2",
          height: "35px" %>
  <% end %>
  <p><%= user.username %></p>
  <p><%= user.email %></p>
  <p><i class="fa-solid fa-location-dot"></i> <%= user.address %></p>


</div>
<nav class="fixed-top p-2 border-bottom bg-nav justify-content-around d-none d-md-flex" id="desktop-nav">

  <%= link_to owner_path, class: "mobile-nav-item c1" do %>
    <i class="fa-solid fa-dice red-light"></i>
    <span>Tes jeux</span>
  <% end %>

  <%= link_to "#modalAddGame", class: "mobile-nav-item", data: { bs_toggle: "modal", bs_target: "#modalAddGame" } do %>
    <i class="fa-solid fa-square-plus red-light"></i>
    <span>Ajoute un jeu</span>
  <% end %>

  <%= link_to borrow_path, class: "mobile-nav-item c2" do %>
    <i class="fa-solid fa-list-check blue-light"></i>
    <span>Tes Share</span>
  <% end %>

  <div class="dropdown">
    <% if user_signed_in? %>


      <a href="#"
       class="mobile-nav-item dropdown-toggle"
       data-bs-toggle="dropdown"
       aria-expanded="false">
        <i class="fa-solid fa-user c3"></i>
        <span>Profil</span>
      </a>

      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <%= link_to "Mon profil",
            profile_path,
            class: "dropdown-item" %>
        </li>

        <li><hr class="dropdown-divider"></li>

        <li>
          <%= link_to "Déconnexion",
            destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "dropdown-item text-danger" %>
        </li>
      </ul>


    <% else %>


      <a href="#"
      class="mobile-nav-item dropdown-toggle"
      data-bs-toggle="dropdown"
      aria-expanded="false">
        <i class="fa-solid fa-user"></i>
        <span>Compte</span>
      </a>

      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <%= link_to "Connexion",
            new_user_session_path,
            class: "dropdown-item" %>
        </li>

        <li>
          <%= link_to "Inscription",
            new_user_registration_path,
            class: "dropdown-item" %>
        </li>
      </ul>


    <% end %>
  </div>

</nav>

<nav class="mobile-nav d-md-none">

  <%= link_to owner_path, class: "mobile-nav-item c1" do %>
    <i class="fa-solid fa-dice red-light"></i>
