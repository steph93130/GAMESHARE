       aria-expanded="false">
        <i class="fa-solid fa-user c3"></i>
        <span>Profile</span>
      </a>

      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <%= link_to "Mon profil",
            profile_path,
            class: "dropdown-item" %>
        </li>

        <li><hr class="dropdown-divider"></li>

        <li>
          <%= link_to "Déconnexion",
            destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "dropdown-item text-danger" %>
        </li>
      </ul>


    <% else %>


      <a href="#"
       class="mobile-nav-item dropdown-toggle"
       data-bs-toggle="dropdown"
       aria-expanded="false">
        <i class="fa-solid fa-user"></i>
        <span>Compte</span>
      </a>

      <ul class="dropdown-menu dropdown-menu-end">
        <li>
          <%= link_to "Connexion",
            new_user_session_path,
            class: "dropdown-item" %>
        </li>

        <li>
          <%= link_to "Inscription",
            new_user_registration_path,
            class: "dropdown-item" %>
        </li>
      </ul>


    <% end %>
  </div>

</nav>

<%= render "shared/modal_ajout_jeu",  game:game %>
