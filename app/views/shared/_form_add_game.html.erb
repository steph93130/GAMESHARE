<div class="container">
  <div class="row justify-content-center">
    <div class="game-card p-4 col-12 col-lg-8" id="ajout">
      <%= form_with model: game, local: true, html: { multipart: true }, class: "row g-3" do |f| %>

        <div class="col-12">
          <%= f.label :title, "Titre", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", id: "game_title" %>
        </div>

        <div class="col-12">
          <%= f.label :condition, "État", class: "form-label" %>
          <%= f.select :condition,
            ["Bon", "Moyen", "Usagé"],
            { prompt: "Choisir un état" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <%= f.label :picture, "Image du jeu", class: "form-label" %>
          <%= f.file_field :picture, class: "form-control", id: "game_picture" %>
        </div>

        <div class="col-12">
          <%= f.label :rent_duration, "Durée de location", class: "form-label" %>
          <%= f.select :rent_duration,
            [["1 jour", 1], ["3 jours", 3], ["7 jours", 7], ["14 jours", 14]],
            { prompt: "Choisir une durée" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <%= f.label :age, "Âge recommandé", class: "form-label" %>
          <%= f.select :age,
            [["3+", 3], ["6+", 6], ["7+", 7], ["10+", 10],["12+", 16],["16+", 16]],
            { prompt: "Choisir un âge" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <%= f.label :player_number, "Nombre de joueurs", class: "form-label" %>
          <%= f.select :player_number,
            [["1", 1], ["2", 2], ["4", 4], ["5", 5], ["6+", 6]],
            { prompt: "Choisir" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <%= f.label :category, "Catégorie", class: "form-label" %>
          <%= f.select :category,
            [
              "Jeu familial", "Jeu expert", "Jeu d'ambiance", "Jeu de cartes",
              "Jeu coopératif", "Jeu de stratégie", "Jeu de gestion", "Jeu de placement",
              "Jeu de draft", "Jeu d'enquête", "Escape game", "Jeu de rôle",
              "Jeu de figurines", "Jeu d'affrontement", "Jeu abstrait", "Jeu enfant"
            ],
            { prompt: "Choisir une catégorie" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-control" %>
        </div>

        <%# ── Champ Règles du jeu avec bouton IA ── %>
        <div class="col-12">
          <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
            <%= f.label :rules, "Règles du jeu", class: "form-label mb-1" %>
            <button type="button" id="fetch-rules-btn" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
              <span id="fetch-rules-icon">✨</span>
              <span id="fetch-rules-label">Générer via l'IA</span>
              <span id="fetch-rules-spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
          </div>

          <div id="fetch-rules-alert" class="alert alert-danger py-2 d-none" role="alert"></div>

          <%= f.text_area :rules, rows: 6, class: "form-control font-monospace", id: "game_rules",
              placeholder: "Saisissez les règles ici, ou cliquez sur \"Générer via l'IA\"." %>

          <%# Aperçu du rendu HTML %>
          <div id="rules-preview-wrapper" class="mt-3 d-none">
            <div class="d-flex justify-content-between align-items-center mb-1">
              <small class="text-muted fw-semibold">Aperçu du rendu</small>
              <button type="button" id="toggle-preview-btn" class="btn btn-link btn-sm p-0 text-muted">Masquer</button>
            </div>
            <div id="rules-preview" class="border rounded p-3 bg-light" style="min-height: 60px;"></div>
          </div>
        </div>

        <div class="col-12">
          <%= f.label :deposit, "Caution", class: "form-label" %>
          <%= f.select :deposit,
            [["5 €", 5], ["10 €", 10], ["15 €", 15], ["20 €", 20]],
            { prompt: "Choisir une caution" },
            class: "form-select" %>
        </div>

        <div class="col-12">
          <div class="form-check">
            <%= f.check_box :available, class: "form-check-input" %>
            <%= f.label :available, "Disponible", class: "form-check-label" %>
          </div>
        </div>

        <div class="col-12 text-center mt-4">
          <%= f.submit "Créer le jeu", class: "btn btn-primary rounded-5 px-4" %>
        </div>

      <% end %>
    </div>

    <script>
    document.addEventListener("DOMContentLoaded", function () {
      const fetchBtn     = document.getElementById("fetch-rules-btn");
      const fetchLabel   = document.getElementById("fetch-rules-label");
      const fetchIcon    = document.getElementById("fetch-rules-icon");
      const fetchSpinner = document.getElementById("fetch-rules-spinner");
      const alertBox     = document.getElementById("fetch-rules-alert");
      const textarea     = document.getElementById("game_rules");
      const previewWrap  = document.getElementById("rules-preview-wrapper");
      const preview      = document.getElementById("rules-preview");
      const toggleBtn    = document.getElementById("toggle-preview-btn");
      const csrfToken    = document.querySelector('meta[name="csrf-token"]').content;

      // ── Mise à jour de l'aperçu en temps réel ──
      textarea.addEventListener("input", function () {
        if (!previewWrap.classList.contains("d-none")) {
          preview.innerHTML = this.value;
        }
      });

      // ── Toggle aperçu ──
      toggleBtn.addEventListener("click", function () {
        const hidden = preview.classList.toggle("d-none");
        toggleBtn.textContent = hidden ? "Afficher" : "Masquer";
      });

      // ── Bouton IA ──
      fetchBtn.addEventListener("click", async function () {
        const title      = document.getElementById("game_title").value.trim();
        const imageInput = document.getElementById("game_picture");

        alertBox.classList.add("d-none");

        if (!title) {
          alertBox.textContent = "Veuillez d'abord renseigner le titre du jeu.";
          alertBox.classList.remove("d-none");
          return;
        }

        // État chargement
        fetchBtn.disabled = true;
        fetchIcon.classList.add("d-none");
        fetchSpinner.classList.remove("d-none");
        fetchLabel.textContent = "Génération en cours…";

        try {
          const body = new FormData();
          body.append("title", title);
          if (imageInput && imageInput.files[0]) {
            body.append("image", imageInput.files[0]);
          }

          const response = await fetch("<%= fetch_rules_games_path %>", {
            method: "POST",
            headers: { "X-CSRF-Token": csrfToken },
            body
          });

          const data = await response.json();

          if (!response.ok || data.error) {
            throw new Error(data.error || "Erreur serveur");
          }

          textarea.value         = data.rules;
          preview.innerHTML      = data.rules;
          previewWrap.classList.remove("d-none");

        } catch (err) {
          alertBox.textContent = "Erreur : " + err.message;
          alertBox.classList.remove("d-none");
        } finally {
          fetchBtn.disabled = false;
          fetchIcon.classList.remove("d-none");
          fetchSpinner.classList.add("d-none");
          fetchLabel.textContent = "Générer via l'IA";
        }
      });
    });
    </script>
  </div>
</div>
