<div class="container" data-controller="ai-generator" data-ai-generator-url-value="<%= fetch_rules_games_path %>">
  <div class="row justify-content-center">
    <div class="game-card p-4 col-12 col-lg-8" >
      <%= form_with model: game, local: true, html: { multipart: true }, class: "row g-3" do |f| %>

        <div class="col-12">
          <%= f.label :title, "Titre", class: "form-label2" %>
          <%= f.text_field :title, class: "form-control rounded-pill", id: "game_title", data: { ai_generator_target: "title" } %>
        </div>

        <div class="col-12">
          <%= f.label :condition, "État", class: "form-label2" %>
          <%= f.select :condition,
            ["Bon", "Moyen", "Usagé"],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <div class="col-12">
          <%= f.label :picture, "Image du jeu", class: "form-label2" %>
          <%= f.file_field :picture, class: "form-control rounded-pill", id: "game_picture", data: { ai_generator_target: "image" } %>
        </div>

        <div class="col-12">
          <%= f.label :rent_duration, "Durée de location", class: "form-label2" %>
          <%= f.select :rent_duration,
            [["1 jour", 1], ["3 jours", 3], ["7 jours", 7], ["14 jours", 14]],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <div class="col-12">
          <%= f.label :age, "Âge recommandé", class: "form-label2" %>
          <%= f.select :age,
            [["3+", 3], ["6+", 6], ["7+", 7], ["10+", 10],["12+", 16],["16+", 16]],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <div class="col-12">
          <%= f.label :player_number, "Nombre de joueurs", class: "form-label2" %>
          <%= f.select :player_number,
            [["1", 1], ["2", 2], ["4", 4], ["5", 5], ["6+", 6]],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <div class="col-12">
          <%= f.label :category, "Catégorie", class: "form-label2" %>
          <%= f.select :category,
            [
              "Jeu familial", "Jeu expert", "Jeu d'ambiance", "Jeu de cartes",
              "Jeu coopératif", "Jeu de stratégie", "Jeu de gestion", "Jeu de placement",
              "Jeu de draft", "Jeu d'enquête", "Escape game", "Jeu de rôle",
              "Jeu de figurines", "Jeu d'affrontement", "Jeu abstrait", "Jeu enfant"
            ],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <%# ── Bouton unique IA ── %>
        <button type="button" 
          data-ai-generator-target="button"
          data-action="click->ai-generator#generate"
          class="btn btn-outline-primary d-inline-flex align-items-center gap-2 rounded-2 px-4">
          <span data-ai-generator-target="icon" id="fetch-ai-icon">✨</span>
          <span data-ai-generator-target="label" id="fetch-ai-label" class="text-info-emphasis">Générer la description et les règles via l'IA</span>
          <span data-ai-generator-target="spinner" id="fetch-ai-spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
        </button>
        <div data-ai-generator-target="alert" id="fetch-ai-alert" class="alert alert-danger py-2 mt-2 d-none" role="alert"></div>

        <%# ── Champ Description ── %>
        <div class="col-12">
          <%= f.label :description, "Description", class: "form-label2" %>
          <%= f.text_area :description, rows: 3, class: "form-control rounded-4", id: "game_description",
              data: { ai_generator_target: "description" },
              placeholder: "Description" %>
        </div>

        <%# ── Champ Règles du jeu ── %>
        <div class="col-12">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <%= f.label :rules, "Règles du jeu", class: "form-label2 mb-0" %>
            <button type="button" data-ai-generator-target="editButton" id="edit-rules-btn" data-action="click->ai-generator#showTextarea" class="btn btn-link btn-sm p-0 text-white text-decoration-none d-none">Modifier</button>
          </div>

          <%= f.text_area :rules, rows: 6, class: "form-control rounded-4 font-monospace", id: "game_rules",
              data: { ai_generator_target: "rules" },
              placeholder: "Règles du jeu" %>

          <%# Aperçu du rendu HTML ── affiché à la place du textarea après génération ── %>
          <div data-ai-generator-target="previewWrapper" id="rules-preview-wrapper" class="d-none">
            <div  data-ai-generator-target="preview" id="rules-preview" class="text-start border rounded-4 p-3 bg-secondary bg-opacity-10"></div>
            <small class="text-muted">Généré par <%= image_tag("logomax.png", size: "16", alt: "Logo GameShare") %> — clique sur <em>Modifier</em> pour éditer le texte brut.</small>
          </div>
        </div>

        <div class="col-12">
          <%= f.label :deposit, "Caution", class: "form-label2" %>
          <%= f.select :deposit,
            [["5 €", 5], ["10 €", 10], ["15 €", 15], ["20 €", 20]],
            { prompt: "Choisi" },
            class: "form-select rounded-pill" %>
        </div>

        <div class="col-12">
          <div class="form-check">
            <%= f.check_box :available, class: "form-check-input" %>
            <%= f.label :available, "Disponible", class: "form-check-label" %>
          </div>
        </div>

        <div class="col-12 text-center mt-4">
          <%= f.submit "Enregistre le jeu !", class: "btn button rounded-5 px-4" %>
        </div>

      <% end %>
    </div>

    
  </div>
</div>
