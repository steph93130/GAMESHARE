<div class="form-rating-container">
  <div class="row justify-content-center form-rating">
    <div class="p-4 col-12 col-lg-8" id="ajout form-rating">
      <%= form_with  do |f| %>
      <div class="col-12 form-rating">
          <%= f.label :rating, "#{user.username}, comment ça s'est passé ? (une note entre 0  et 5 ⭐)" , class: "form-label" %>
          <%= f.number_field :rating, in: 0.0..5.0, step: 0.5, class: "form-control rounded-3", id: "rating" %>
        </div>
        <div class="col-12 text-center mt-4 form-rating">
          <%= f.submit "✨ Comment ça s'est passé ?", class: "btn button rounded-5 px-4" %>
        </div>
        <% end %>
      </div>
    </div>
</div>
