<div class="form-rating-card" data-controller="star-rating">
  <%= form_with url: rate_booking_path(booking), method: :patch do |f| %>
    <%= f.hidden_field :rated_role, value: rated_role %>

    <div class="form-rating-header">
      <div class="form-rating-avatar">
        <%= rated_user.username[0].upcase %>
      </div>
      <p class="form-rating-question">Comment s'est passé l'emprunt avec</p>
      <h3 class="form-rating-username"><%= rated_user.username %> ?</h3>
    </div>

    <div class="form-rating-body">
      <div class="star-selector"
           data-star-rating-target="starsList"
           data-action="mouseleave->star-rating#resetHover">
        <% (1..5).each do |i| %>
          <span class="star-item"
                data-action="mouseenter->star-rating#hover click->star-rating#select"
                data-value="<%= i %>">
            <i class="fa-star fa-regular"></i>
          </span>
        <% end %>
      </div>

      <p class="rating-hint" data-star-rating-target="label">Clique sur une étoile pour noter</p>

      <%= f.hidden_field :score, value: 0, data: { "star-rating-target": "input" } %>
    </div>

    <div class="form-rating-footer">
      <%= f.submit "Envoyer ma note",
          class: "btn button rounded-5 px-5",
          data: { "star-rating-target": "submit" },
          disabled: true %>
      <button type="button"
              class="btn-skip"
              data-action="click->star-rating#skip"
              aria-label="Passer la notation">
        Passer
      </button>
    </div>
  <% end %>
</div>
