<div id="inline_chat_container" class="container chat"
  data-controller="chat-subscription"
  data-chat-subscription-chat-id-value="<%= @chat.id %>"
>
  <h1 id="titre" class="mt-2 ms-3">Chat avec <%= @other_user.username %> pour le jeu <%= @game.title %></h1>

  <div id="messages" data-chat-subscription-target="messages" class="col-10 col-lg-6 mx-auto">
    <% @chat.messages.each do |message| %>
      <%= render "messages/message", message: message, mine: message.user == current_user %>
    <% end %>
  </div>

  <div id="new_message_container" class="col-10 col-lg-6 mx-auto">
    <%= render "messages/form", chat: @chat, message: @message %>
  </div>

  <% is_owner = @chat.game.user == current_user %>
  <div class="d-flex justify-content-center align-items-center gap-3">
    <% if is_owner %>
      <%= turbo_stream_from "chat_#{@chat.id}_booking_actions" %>
    <% else %>
      <%= turbo_stream_from "game_#{@game.id}_inline_chat" %>
      <%= turbo_stream_from "chat_#{@chat.id}_booking_actions_borrower" %>
      <button class="button" onclick="window.close()">← <%= @game.title %></button>
    <% end %>

    <%= render "chats/booking_actions", chat: @chat, booking: @chat.booking, is_owner: is_owner %>
  </div>
</div>
