
<%= simple_form_for [chat, message], html: { data: { controller: "stopbutton" } } do |f| %>
  <%= f.input :content,
              label: "Poser une question",
              required: true,
              placeholder: "Echanger ici.",
              input_html: { class: "input_ask",
                            data: { action: "input->stopbutton#update",
                                    stopbutton_target: "input" } }
  %>
  <%= f.button :submit, "Echanger",
               class: "btn btn-outline-secondary rounded-pill mb-3",
               title: "Lancer le chat",
               disabled: true,
               data: { stopbutton_target: "button" }
  %>
<% end %>
