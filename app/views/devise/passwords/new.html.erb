<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">
      <h2 class="mb-4 text-center h2">
  <span style="display:inline-block"><span class="red">F</span><span class="blue">o</span><span class="yellow">r</span><span class="orange">g</span><span class="green">o</span><span class="purple">t</span></span>
  <span style="display:inline-block"><span class="red">y</span><span class="blue">o</span><span class="yellow">u</span><span class="orange">r</span></span>
  <span style="display:inline-block"><span class="green">p</span><span class="purple">a</span><span class="red">s</span><span class="blue">s</span><span class="yellow">w</span><span class="orange">o</span><span class="green">r</span><span class="purple">d</span><span class="red">?</span></span>
</h2>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <%= f.input :email,
                      required: true,
                      autofocus: true,
                      input_html: { autocomplete: "email", class: "form-control" } %>
        </div>

        <div class="form-actions mt-3 d-grid">
          <%= f.button :submit, "Send me password reset instructions", class: "button w-100" %>
        </div>
      <% end %>

      <div class="mt-3">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
