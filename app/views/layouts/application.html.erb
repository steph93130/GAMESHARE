<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gameshare" %></title>

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="application-name" content="Gameshare">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <%# Favicon - placer le fichier dans public/favicon.ico %>
    <%= favicon_link_tag asset_path('favicon.ico') %>

    <%# Assets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": Rails.env.production? ? "reload" : "" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= ['bg-red-light', 'bg-blue-light', 'bg-yellow-light', 'bg-orange-light', 'bg-green-light', 'bg-purple-light'].sample %> min-vh-100">

  <% if current_page?(root_path) %>
    <%= render "shared/logo1" %>
    <%= render "shared/nav" %>
  <% elsif current_page?(profile_path) %>
    <%= render "shared/navbar_profil", game: @game, user: @user %>
  <% elsif current_page?(edit_user_registration_path) %>
    <%= render "shared/logo1" %>
  <% else %>
    <%= render "shared/logo0" %>
    <%= render "shared/nav" %>
  <% end %>
  <%= yield %>
  <p class="notice"><%= notice %></p>
  <p class="alert"><%= alert %></p>

  <%= render "shared/flashes" %>

</body>
</html>
