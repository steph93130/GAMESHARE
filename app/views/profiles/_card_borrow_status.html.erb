<div class="col-12 col-md-6 col-lg-4 col-xl-2 mb-4">
    <div class="mini-card">
        <%= link_to "#", class: "mini-card-link" do %>
            <p class="text-danger fw-semibold"><i class="fa-solid fa-crown yellow"></i> <%= b.game.title %></p>
            <p class="text-success">Statut :  <%= b.status %> </p>
            <p class="text-success">Emprunté par :  <%= b.chat.user.username %></p>
            <% if b.status == "accepted" %>
                <p><%=  "par #{b.game.user.username}" %></p>
                <p><%= link_to "", deposit_booking_path(b), class:"fa-solid fa-basket-shopping fs-1 green" %></p>
                <p><i class="fa-solid fa-chevron-up"></i></p>
                <p  class="fs-6 text confirmer"><%= b.user.username %> clique ici pour valider définitivement.</p>
            <% elsif b.status == "returned" %>
                <p><%=  "par #{b.game.user.username}" %></p>
                <p><%= link_to "", give_back_booking_path(b), class:"fa-solid fa-euro-sign fs-1 green" %></p>
                <p><i class="fa-solid fa-chevron-up"></i></p>
                <p  class="fs-6 text confirmer"><%= b.user.username %> clique ici pour récupéré ta caution.</p>
            <% elsif b.status == "validated" %>
                <p><%=  "par #{b.game.user.username}" %></p>
                <p><%= link_to "", owner_path, class:"fa-solid fa-check fs-1 green" %></p>
                <p><i class="fa-solid fa-chevron-up"></i></p>
                <p  class="fs-6 text confirmer"><%= b.user.username %> clique ici pour valider le retour du jeux.</p>
            <% else %>
                <%= "par #{current_user.username}" %>
            <% end %>
        <% end %>
    </div>
</div>
