<% provide(:title, "gameshare - votre profil") %>

<div class="container">

<div class="rating">
<p class="text-rating text-paytone"><%= @user.username %>, ton statut sur GameShare depuis ton inscription <span>(<%= l(@user.created_at.to_date, format: :long, locale: :fr) %>)</span></p>
  <div class="calcul-rating">
    <% user_rating = @user.rating.round(1) %>
<% if user_rating == 0 %>
  <p>⭐ Nouveau venu</p>
<% elsif user_rating > 0  && user_rating <= 2 %>
  <p>🌱 Prometteur</p>
<% elsif user_rating > 2  && user_rating <= 3 %>
  <p>🌟 Bien apprécié par la communauté</p>
<% elsif user_rating > 3 && user_rating <= 4 %>
<p>🏅 Membre recommandé</p>
<% elsif user_rating > 4 %>
<p>🚀 Top profil</p>
<% end %>
  </div>
</div>
<div class="main-profil">
  <%= link_to owner_path do %>
  <div class="ma-ludo card-profil">
    <p><i class="fa-solid fa-dice purple"></i> MA LUDOTHEQUE</p>
    <p><i class="fa-solid fa-angle-right"></i></p>
  </div>
  <% end %>
  <%= link_to "#modalAddGame", data: { bs_toggle: "modal", bs_target: "#modalAddGame" } do %>
  <div class="ajouter-jeu card-profil">
    <p><i class="fa-brands fa-square-google-plus purple"></i> AJOUTER MON JEU</p>
    <p><i class="fa-solid fa-angle-right"></i></p>
  </div>
<% end %>
  <%= link_to borrow_path do %>
  <div class="mes-emprunts card-profil">
    <p><i class="fa-solid fa-euro-sign purple"></i> MES EMPRUNTS</p>
    <p><i class="fa-solid fa-angle-right"></i></p>
  </div>
  <% end %>
</div>
<%= render "shared/modal_ajout_jeu", user: @user, game:@game %>
</div>
