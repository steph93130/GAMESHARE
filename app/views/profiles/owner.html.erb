<div class="container">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">
      <div class="border rounded-4 p-4">
        <div class="d-flex gap-3 mb-4 justify-content-center">
          <%= link_to "Ma ludothèque", "#ludo", class: "btn btn-primary rounded-pill" %>
          <%= link_to "Ajouter un jeu", "#",
              class: "btn btn-outline-primary rounded-pill",
              data: { bs_toggle: "modal", bs_target: "#modalAddGame" } %>
          <%= link_to "Mes emprunts", borrow_path, class: "btn btn-outline-primary rounded-pill" %>
      </div>
      <% if @games.any? %>
        <div class="row" id="ludo">
          <% @games.each do |game| %>
            <div class="col-12 col-md-6 col-lg-4 col-xl-2 mb-4">
              <div class="mini-card">
                <%= button_to toggle_availability_game_path(game), method: :patch,
                    class: "availability-toggle btn border-0 bg-transparent p-0" do %>
                  <i class="fa-solid <%= game.available? ? 'fa-toggle-on text-success' : 'fa-toggle-off text-secondary' %> fs-5"></i>
                  <span class="d-block text-dark" style="font-size: 0.7rem; line-height: 1.2;">
                    <%= game.available? ? "Disponible" : "Indisponible" %>
                  </span>
                <% end %>
                <%= link_to game_path(game), class: "mini-card-link" do %>
                  <p class="fs-4 text" class="game-title">
                    <%= game.title %>
                  </p>
                  <% if game.picture.attached? %>
                    <%= cl_image_tag game.picture.key,
                        alt: game.title,
                        class: "game-image img-fluid" %>
                    <% else %>
                    <div class="bg-secondary d-flex align-items-center justify-content-start rounded"
                          style="height: 220px;">
                        Aucune image
                    </div>
                  <% end %>
                  <p class="text-start"><i class="fa-solid fa-dice red"></i> <%= game.category %></p>
                  <p class="text-start"><i class="fa-solid fa-dice-d20 blue"></i> <%= game.age %> ans</p>
                  <p class="text-start"><i class="fa-solid fa-chess-knight orange"></i> <%= game.player_number %> joueur<%= game.player_number > 1 ? 's' : "" %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center">
        <p>Aucun jeu ajouté pour le moment.</p>
        </div>
      <% end %>
      </div>
    </div>
  </div>
<hr>
</div>

<div class="modal fade" id="modalAddGame" tabindex="-1" aria-labelledby="modalAddGameLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalAddGameLabel">Ajouter un jeu</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body">
        <%= render "shared/form_add_game", game: @game %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary rounded-pill"
                data-bs-dismiss="modal">Annuler</button>
      </div>
    </div>
  </div>
</div>
<p>===================================</p>

<div class="global-main d-flex flex-wrap gap-3 w-75 mx-auto">
  <% @games.each do |game| %>
    <% game.chats.each do |chat| %>
      <% if chat.booking.nil? %>
        <p>nil</p>
        <p><%= chat.id %></p>
      <% elsif chat.booking.status === "accepted" %>
        <div class="game-card p-4 w-50 mx-auto d-flex flex-column bg-success-emphasis ">
          <p class="text-danger fw-semibold"><i class="fa-solid fa-crown yellow"></i> <%= game.title %></p>
          <p class="text-warning">Statut :  <%= chat.booking.status %> </p>
          <p class="text-success">Emprunté par :  <%= chat.user.username %></p>
        </div>
      <% elsif chat.booking.status === "validated" %>
        <div class="game-card p-4 w-50 mx-auto d-flex flex-column bg-success-emphasis ">
          <p class="text-danger fw-semibold"><i class="fa-solid fa-crown yellow"></i> <%= game.title %></p>
          <p class="text-danger">Statut :  <%= chat.booking.status %> </p>
          <p class="text-success">Emprunté par :  <%= chat.user.username %></p>
          <p><%= link_to "Rendu ?", returned_booking_path(chat.booking), data: { turbo_method: :patch } %></p>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
