<p>mes prêts</p>
<!-- liste des jeux prêter avec leur statut -->
<% if !@owner.empty? %>
  <div class="row" id="ludo">

    <% @owner[:submited].each do |booking| %>
      <%= render "profiles/card_status", b: booking  %>
    <% end %>

    <% @owner[:validated].each do |booking| %>
      <%= render "profiles/card_status", b: booking  %>
    <% end %>
    
  </div>
<% else %>
  <div class="text-center">
    <p><%= current_user.username %>, tu n'as aucun emprunt actuellement.</p>
  </div>
<% end %>
<%# raise %>
<!-- Fin test liste des jeux prêter avec leur statut -->
<p>mes emprunts</p>
<!-- liste des jeux empruntés avec leur statut -->
<% if !@borrow.empty? %>
  <div class="row" id="ludo">
    
    <% @borrow[:accepted].each do |booking| %>
      <%= render "profiles/card_status", b: booking  %>
    <% end %>
    
    <% @borrow[:returned].each do |booking| %>
      <%= render "profiles/card_status", b: booking  %>
    <% end %>
  </div>
<% else %>
  <div class="text-center">
    <p><%= current_user.username %>, tu n'as aucun emprunt actuellement.</p>
  </div>
<% end %>
<%# raise %>
<!-- Fin test liste des jeux empruntés avec leur statut -->

<!-- Cloture preteur-->
<p>jeux prété cloturé</p>
<% if !@owner.empty? %>
  <% @owner[:closed].each do |booking| %>
    <%= render "profiles/card_status", b: booking  %>
  <% end %>
<% end %>
<!-- FIN cloture -->
<!-- Cloture preteur-->
<p>jeux empunté cloturé</p>
<% if !@borrow.empty? %>
  <% @borrow[:closed].each do |booking| %>
    <%= render "profiles/card_status", b: booking  %>
  <% end %>
<% end %>
<!-- FIN cloture -->

<%# raise %>